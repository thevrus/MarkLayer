{
  "name": "marklayer",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check": "turbo check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "deploy": "turbo build && cd apps/worker && bun run deploy"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@resvg/resvg-wasm": "^2.6.2"
  }
}
